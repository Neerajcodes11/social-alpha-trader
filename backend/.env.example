# Groq Cloud API Key — free at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Starknet network: "sepolia" for testnet, "mainnet" for production
STARKNET_NETWORK=sepolia

# Private key for StarkZap signer (testnet only — never expose in prod)
# Get test tokens: https://starknet-faucet.vercel.app/
STARKNET_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Recipient address for demo trades (your own wallet address on Sepolia)
STARKNET_RECIPIENT_ADDRESS=0xYOUR_WALLET_ADDRESS_HERE

# Port
PORT=3001
